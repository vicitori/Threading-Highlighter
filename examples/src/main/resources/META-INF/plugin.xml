<idea-plugin>
    <id>io.github.vicitori.threading.highlighter.examples</id>
    <name>Highlighter Examples</name>
    <vendor>Vicitori</vendor>

    <description><![CDATA[
    The set of examples demonstrating typical threading bugs in IntelliJ plugins.
    ]]></description>

    <idea-version since-build="253" until-build="253.*"/>

    <depends>com.intellij.modules.platform</depends>

    <extensions defaultExtensionNs="com.intellij">
        <notificationGroup id="Main Group" displayType="BALLOON"/>
    </extensions>

    <actions>
        <group id="io.github.vicitori.threading.highlighter.examples.MainGroup" text="Threading Marker Examples" popup="true">
            <action id="io.github.vicitori.threading.highlighter.examples.SlowOperationOnEdtAction"
                    class="io.github.vicitori.threading.highlighter.examples.SlowOperationOnEdtAction"
                    text="All Markers (Combined Example)"
                    description="Demonstrates all three threading markers: SLOW_OPERATION, EDT, and NON_EDT">
                <keyboard-shortcut keymap="$default" first-keystroke="shift X"/>
            </action>

            <action id="io.github.vicitori.threading.highlighter.examples.EdtMarkerAction"
                    class="io.github.vicitori.threading.highlighter.examples.EdtMarkerAction"
                    text="EDT Marker Only"
                    description="Demonstrates assertIsDispatchThread() marker">
                <keyboard-shortcut keymap="$default" first-keystroke="shift E"/>
            </action>

            <action id="io.github.vicitori.threading.highlighter.examples.NonEdtMarkerAction"
                    class="io.github.vicitori.threading.highlighter.examples.NonEdtMarkerAction"
                    text="Non-EDT Marker Only"
                    description="Demonstrates assertIsNonDispatchThread() marker">
                <keyboard-shortcut keymap="$default" first-keystroke="shift N"/>
            </action>

            <action id="io.github.vicitori.threading.highlighter.examples.ChainedMarkersAction"
                    class="io.github.vicitori.threading.highlighter.examples.ChainedMarkersAction"
                    text="Chained Markers Example"
                    description="Demonstrates chain of calls with multiple threading markers">
                <keyboard-shortcut keymap="$default" first-keystroke="shift Y"/>
            </action>
        </group>
    </actions>
</idea-plugin>
